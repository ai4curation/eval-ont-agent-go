{"type":"tool_use","timestamp":1778467471874,"sessionID":"ses_1eb16cf69ffe0NFs3tYbe8SbrI","part":{"type":"tool","tool":"bash","callID":"functions.bash:33","state":{"status":"completed","input":{"command":"python3 -c \"\nimport sys\n\n# Basic OBO sanity checks\nfile = 'src/ontology/go-edit.obo'\nwith open(file) as f:\n    content = f.read()\n\n# Check no trailing whitespace in lines\nviolations = []\nfor i, line in enumerate(content.split('\\n'), 1):\n    if line.endswith(' ') or line.endswith('\\t'):\n        violations.append((i, repr(line[:50])))\n\nprint(f'Trailing whitespace violations: {len(violations)}')\nfor v in violations[:5]:\n    print(f'  Line {v[0]}: {v[1]}')\n\n# Check that obsolete term has no is_a or relationship tags defining non-obsolete terms\nfound_issue = False\nin_term = False\nfor i, line in enumerate(content.split('\\n'), 1):\n    if line.startswith('[Term]'):\n        in_term = True\n        term_id = None\n        is_obs = False\n        has_isa = False\n    elif in_term:\n        if line.startswith('id: '):\n            term_id = line[4:]\n        elif line.startswith('is_obsolete: true'):\n            is_obs = True\n        elif line.startswith('is_a:') and not is_obs:\n            has_isa = True\n        elif line == '' or line.startswith('['):\n            in_term = False\n\n# Check no references to obsolete GO:0010381 in other terms\nrefs = content.count('GO:0010381')\nprint(f'References to GO:0010381 in file: {refs}')\n# The obsolete term itself has the id line, and maybe replaced_by\n# Count occurrences in non-obsolete stanzas\nterms = content.split('\\n[Term]')\nref_count = 0\nfor term in terms:\n    if 'is_obsolete: true' not in term:\n        ref_count += term.count('GO:0010381')\nprint(f'References to GO:0010381 in non-obsolete stanzas: {ref_count}')\nprint('Basic checks completed.')\n\"","description":"Run basic OBO sanity checks"},"output":"Trailing whitespace violations: 0\nReferences to GO:0010381 in file: 1\nReferences to GO:0010381 in non-obsolete stanzas: 0\nBasic checks completed.\n","metadata":{"output":"Trailing whitespace violations: 0\nReferences to GO:0010381 in file: 1\nReferences to GO:0010381 in non-obsolete stanzas: 0\nBasic checks completed.\n","exit":0,"description":"Run basic OBO sanity checks","truncated":false},"title":"Run basic OBO sanity checks","time":{"start":1778467471860,"end":1778467471873}},"id":"prt_e14ebec8c001GbgtVyTscwthgv","sessionID":"ses_1eb16cf69ffe0NFs3tYbe8SbrI","messageID":"msg_e14ebdc52001vLOY5H9K3JT4KN"}}
