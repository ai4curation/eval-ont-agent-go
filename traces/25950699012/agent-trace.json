flow run](https://github.com/geneontology/go-ontology/actions/runs/24373255989)\",\n      \"createdAt\": \"2026-04-14T00:05:01Z\",\n      \"includesCreatedEdit\": false,\n      \"isMinimized\": false,\n      \"minimizedReason\": \"\",\n      \"reactionGroups\": [],\n      \"url\": \"https://github.com/geneontology/go-ontology/issues/31863#issuecomment-4240390267\",\n      \"viewerDidAuthor\": false\n    },\n    {\n      \"id\": \"IC_kwDOAkAHws79qkCy\",\n      \"author\": {\n        \"login\": \"raymond91125\"\n      },\n      \"authorAssociation\": \"MEMBER\",\n      \"body\": \"[Term]\\nid: GO:7770062\\nname: vesicle membrane tethering activity\\nnamespace: molecular_function\\ndef: \\\"A membrane-membrane adaptor activity that provides the first point of contact and physically bridges the vesicle membrane and its target membrane prior to vesicle docking and fusion.\\\" [PMID:19575650, PMID:19887069]\\nsynonym: \\\"vesicle membrane tether activity\\\" EXACT []\\nsynonym: \\\"vesicle tethering activity\\\" EXACT []\\nis_a: GO:0140177 ! membrane-membrane adaptor activity\\nproperty_value: term_tracker_item \\\"https://github.com/geneontology/go-ontology/issues/31863\\\" xsd:anyURI\\ncreated_by: dragon-ai-agent\\ncreation_date: 2026-04-13T23:43:55Z\",\n      \"createdAt\": \"2026-04-15T21:45:03Z\",\n      \"includesCreatedEdit\": false,\n      \"isMinimized\": false,\n      \"minimizedReason\": \"\",\n      \"reactionGroups\": [],\n      \"url\": \"https://github.com/geneontology/go-ontology/issues/31863#issuecomment-4255793330\",\n      \"viewerDidAuthor\": false\n    }\n  ],\n  \"title\": \"NTR: MF vesicle membrane tethering activity\",\n  \"url\": \"https://github.com/geneontology/go-ontology/issues/31863\"\n}\n","exit_code":0,"status":"completed"}}
