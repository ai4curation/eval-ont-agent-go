": \"pending\",\n    \"priority\": \"high\"\n  }\n]","metadata":{"todos":[{"content":"Analyze issue and create plan for obsoleting GO:0140057","status":"in_progress","priority":"high"},{"content":"Pre-validation: validate ontology before changes","status":"pending","priority":"high"},{"content":"Load term-obsoletion skill and follow its procedures","status":"pending","priority":"high"},{"content":"Find GO:0140057 and check references to it in the ontology","status":"pending","priority":"high"},{"content":"Perform edits to obsolete the term","status":"pending","priority":"high"},{"content":"Run automated validation","status":"pending","priority":"high"},{"content":"Commit changes","status":"pending","priority":"high"},{"content":"Create ISSUE_COMMENTS.md and PR_COMMENTS.md","status":"pending","priority":"high"}],"truncated":false},"title":"8 todos","time":{"start":1778467283919,"end":1778467283922}},"id":"prt_e14e91eac0011fQwVHFWptdcPT","sessionID":"ses_1eb170a27ffewZijCRpUyazl8z","messageID":"msg_e14e914dd001bCQ3QG02M4STIN"}}
