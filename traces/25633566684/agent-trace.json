{"type":"item.completed","item":{"id":"item_28","type":"command_execution","command":"/bin/bash -lc \"curl -L --fail --silent 'https://www.ebi.ac.uk/europepmc/webservices/rest/search?query=EXT_ID:27243008%20AND%20SRC:MED&format=json&resultType=core&pageSize=1'\"","aggregated_output":"{\"version\":\"6.9\",\"hitCount\":1,\"request\":{\"queryString\":\"EXT_ID:27243008 AND SRC:MED\",\"internalQuery\":\"EXT_ID:27243008 AND SRC:MED\",\"resultType\":\"CORE\",\"cursorMark\":\"*\",\"pageSize\":1,\"sort\":\"\",\"synonym\":false},\"resultList\":{\"result\":[{\"id\":\"27243008\",\"source\":\"MED\",\"pmid\":\"27243008\",\"pmcid\":\"PMC4868844\",\"fullTextIdList\":{\"fullTextId\":[\"PMC4868844\"]},\"doi\":\"10.3389/fcell.2016.00044\",\"title\":\"Coat/Tether Interactions-Exception or Rule?\",\"authorString\":\"Schroeter S, Beckmann S, Schmitt HD.\",\"authorList\":{\"author\":[{\"fullName\":\"Schroeter S\",\"firstName\":\"Saskia\",\"lastName\":\"Schroeter\",\"initials\":\"S\",\"authorAffiliationDetailsList\":{\"authorAffiliation\":[{\"affiliation\":\"Neurobiology, Max Planck Institute for Biophysical Chemistry Göttingen, Germany.\"}]}},{\"fullName\":\"Beckmann S\",\"firstName\":\"Sabrina\",\"lastName\":\"Beckmann\",\"initials\":\"S\",\"authorAffiliationDetailsList\":{\"authorAffiliation\":[{\"affiliation\":\"Neurobiology, Max Planck Institute for Biophysical Chemistry Göttingen, Germany.\"}]}},{\"fullName\":\"Schmitt HD\",\"firstName\":\"Hans Dieter\",\"lastName\":\"Schmitt\",\"initials\":\"HD\",\"authorAffiliationDetailsList\":{\"authorAffiliation\":[{\"affiliation\":\"Neurobiology, Max Planck Institute for Biophysical Chemistry Göttingen, Germany.\"}]}}]},\"dataLinksTagsList\":{\"dataLinkstag\":[\"altmetrics\"]},\"journalInfo\":{\"volume\":\"4\",\"journalIssueId\":2378232,\"dateOfPublication\":\"2016 \",\"monthOfPublication\":0,\"yearOfPublication\":2016,\"printPublicationDate\":\"2016-01-01\",\"journal\":{\"title\":\"Frontiers in cell and developmental biology\",\"medlineAbbreviation\":\"Front Cell Dev Biol\",\"essn\":\"2296-634X\",\"issn\":\"2296-634X\",\"isoabbreviation\":\"Front Cell Dev Biol\",\"nlmid\":\"101630250\"}},\"pubYear\":\"2016\",\"pageInfo\":\"44\",\"abstractText\":\"Coat complexes are important for cargo selection and vesicle formation. Recent evidence suggests that they may also be involved in vesicle targeting. Tethering factors, which form an initial bridge between vesicles and the target membrane, may bind to coat complexes. In this review, we ask whether these coat/tether interactions share some common mechanisms, or whether they are special adaptations to the needs of very specific transport steps. We compare recent findings in two multisubunit tethering complexes, the Dsl1 complex and the HOPS complex, and put them into context with the TRAPP I complex as a prominent example for coat/tether interactions. We explore where coat/tether interactions are found, compare their function and structure, and comment on a possible evolution from a common ancestor of coats and tethers.\",\"affiliation\":\"Neurobiology, Max Planck Institute for Biophysical Chemistry Göttingen, Germany.\",\"publicationStatus\":\"epublish\",\"language\":\"eng\",\"pubModel\":\"Electronic-eCollection\",\"pubTypeList\":{\"pubType\":[\"review-article\",\"Review\",\"Journal Article\"]},\"grantsList\":{\"grant\":[{\"agency\":\"Max-Planck-Gesellschaft\",\"orderIn\":0},{\"agency\":\"Göttinger Graduiertenschule für Neurowissenschaften, Biophysik und Molekulare Biowissenschaften\",\"orderIn\":0}]},\"keywordList\":{\"keyword\":[\"Vesicle Trafficking\",\"Protocoatomer\",\"Coated Vesicles\",\"Tethering Complex\",\"Coat Complexes\"]},\"fullTextUrlList\":{\"fullTextUrl\":[{\"availability\":\"Open access\",\"availabilityCode\":\"OA\",\"documentStyle\":\"pdf\",\"site\":\"Unpaywall\",\"url\":\"https://www.frontiersin.org/articles/10.3389/fcell.2016.00044/pdf\"},{\"availability\":\"Subscription required\",\"availabilityCode\":\"S\",\"documentStyle\":\"doi\",\"site\":\"DOI\",\"url\":\"https://doi.org/10.3389/fcell.2016.00044\"},{\"availability\":\"Open access\",\"availabilityCode\":\"OA\",\"documentStyle\":\"html\",\"site\":\"Europe_PMC\",\"url\":\"https://europepmc.org/articles/PMC4868844\"},{\"availability\":\"Open access\",\"availabilityCode\":\"OA\",\"documentStyle\":\"pdf\",\"site\":\"Europe_PMC\",\"url\":\"https://europepmc.org/articles/PMC4868844?pdf=render\"}]},\"commentCorrectionList\":{\"commentCorrection\":[{\"id\":\"27588286\",\"source\":\"MED\",\"reference\":\"Front Cell Dev Biol. 2016 Aug 30;4:90. doi: 10.3389/fcell.2016.00090\",\"type\":\"Erratum in\",\"orderIn\":1}]},\"isOpenAccess\":\"Y\",\"inEPMC\":\"Y\",\"inPMC\":\"Y\",\"hasPDF\":\"Y\",\"hasBook\":\"N\",\"hasSuppl\":\"N\",\"citedByCount\":10,\"hasData\":\"N\",\"hasReferences\":\"Y\",\"hasTextMinedTerms\":\"Y\",\"hasDbCrossReferences\":\"N\",\"hasLabsLinks\":\"Y\",\"license\":\"cc by\",\"hasEvaluations\":\"N\",\"authMan\":\"N\",\"epmcAuthMan\":\"N\",\"nihAuthMan\":\"N\",\"hasTMAccessionNumbers\":\"N\",\"dateOfCompletion\":\"2016-05-31\",\"dateOfCreation\":\"2016-06-01\",\"firstIndexDate\":\"2016-06-01\",\"fullTextReceivedDate\":\"2020-07-12\",\"dateOfRevision\":\"2020-09-29\",\"electronicPublicationDate\":\"2016-05-17\",\"firstPublicationDate\":\"2016-05-17\"}]}}","exit_code":0,"status":"completed"}}
