om yersinia pestis\",\"volume\":\"275\",\"issue\":\"19\",\"pages\":\"4824-35\",\"lang\":[\"eng\"],\"nlmuniqueid\":\"101229646\",\"issn\":\"1742-464X\",\"essn\":\"\",\"pubtype\":[\"Comparative Study\",\"Journal Article\"],\"recordstatus\":\"PubMed - indexed for MEDLINE\",\"pubstatus\":\"256\",\"articleids\":[{\"idtype\":\"pubmed\",\"idtypen\":1,\"value\":\"18727669\"},{\"idtype\":\"doi\",\"idtypen\":3,\"value\":\"10.1111/j.1742-4658.2008.06621.x\"},{\"idtype\":\"pii\",\"idtypen\":4,\"value\":\"EJB6621\"}],\"history\":[{\"pubstatus\":\"pubmed\",\"date\":\"2008/08/30 09:00\"},{\"pubstatus\":\"medline\",\"date\":\"2008/10/28 09:00\"},{\"pubstatus\":\"entrez\",\"date\":\"2008/08/30 09:00\"}],\"references\":[],\"attributes\":[\"Has Abstract\"],\"pmcrefcount\":\"\",\"fulljournalname\":\"The FEBS journal\",\"elocationid\":\"doi: 10.1111/j.1742-4658.2008.06621.x\",\"doctype\":\"citation\",\"srccontriblist\":[],\"booktitle\":\"\",\"medium\":\"\",\"edition\":\"\",\"publisherlocation\":\"\",\"publishername\":\"\",\"srcdate\":\"\",\"reportnumber\":\"\",\"availablefromurl\":\"\",\"locationlabel\":\"\",\"doccontriblist\":[],\"docdate\":\"\",\"bookname\":\"\",\"chapter\":\"\",\"sortpubdate\":\"2008/10/01 00:00\",\"sortfirstauthor\":\"Kim SK\",\"vernaculartitle\":\"\"}}}\n","exit_code":0,"status":"completed"}}
