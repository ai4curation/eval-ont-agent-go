{"type":"item.completed","item":{"id":"item_33","type":"command_execution","command":"/bin/bash -lc \"curl -fsSL 'https://www.ebi.ac.uk/europepmc/webservices/rest/search?query=EXT_ID:12517450%20AND%20SRC:MED&resultType=core&format=json'\"","aggregated_output":"{\"version\":\"6.9\",\"hitCount\":1,\"request\":{\"queryString\":\"EXT_ID:12517450 AND SRC:MED\",\"internalQuery\":\"EXT_ID:12517450 AND SRC:MED\",\"resultType\":\"CORE\",\"cursorMark\":\"*\",\"pageSize\":25,\"sort\":\"\",\"synonym\":false},\"resultList\":{\"result\":[{\"id\":\"12517450\",\"source\":\"MED\",\"pmid\":\"12517450\",\"doi\":\"10.1016/s0968-0004(02)00003-8\",\"title\":\"Structure, mechanism and regulation of peroxiredoxins.\",\"authorString\":\"Wood ZA, Schröder E, Robin Harris J, Poole LB.\",\"authorList\":{\"author\":[{\"fullName\":\"Wood ZA\",\"firstName\":\"Zachary A\",\"lastName\":\"Wood\",\"initials\":\"ZA\",\"authorAffiliationDetailsList\":{\"authorAffiliation\":[{\"affiliation\":\"Institute of Molecular Biology, Howard Hughes Medical Institute, University of Oregon, Eugene, OR 97403, USA.\"}]}},{\"fullName\":\"Schröder E\",\"firstName\":\"Ewald\",\"lastName\":\"Schröder\",\"initials\":\"E\"},{\"fullName\":\"Robin Harris J\",\"firstName\":\"J\",\"lastName\":\"Robin Harris\",\"initials\":\"J\"},{\"fullName\":\"Poole LB\",\"firstName\":\"Leslie B\",\"lastName\":\"Poole\",\"initials\":\"LB\",\"authorId\":{\"type\":\"ORCID\",\"value\":\"0000-0003-0334-7328\"}}]},\"authorIdList\":{\"authorId\":[{\"type\":\"ORCID\",\"value\":\"0000-0003-0334-7328\"}]},\"dataLinksTagsList\":{\"dataLinkstag\":[\"altmetrics\",\"related_data\",\"wikipedia\"]},\"journalInfo\":{\"issue\":\"1\",\"volume\":\"28\",\"journalIssueId\":1162373,\"dateOfPublication\":\"2003 Jan\",\"monthOfPublication\":1,\"yearOfPublication\":2003,\"printPublicationDate\":\"2003-01-01\",\"journal\":{\"title\":\"Trends in biochemical sciences\",\"medlineAbbreviation\":\"Trends Biochem Sci\",\"isoabbreviation\":\"Trends Biochem Sci\",\"nlmid\":\"7610674\",\"issn\":\"0968-0004\"}},\"pubYear\":\"2003\",\"pageInfo\":\"32-40\",\"abstractText\":\"Peroxiredoxins (Prxs) are a ubiquitous family of antioxidant enzymes that also control cytokine-induced peroxide levels which mediate signal transduction in mammalian cells. Prxs can be regulated by changes to phosphorylation, redox and possibly oligomerization states. Prxs are divided into three classes: typical 2-Cys Prxs; atypical 2-Cys Prxs; and 1-Cys Prxs. All Prxs share the same basic catalytic mechanism, in which an active-site cysteine (the peroxidatic cysteine) is oxidized to a sulfenic acid by the peroxide substrate. The recycling of the sulfenic acid back to a thiol is what distinguishes the three enzyme classes. Using crystal structures, a detailed catalytic cycle has been derived for typical 2-Cys Prxs, including a model for the redox-regulated oligomeric state proposed to control enzyme activity.\",\"affiliation\":\"Institute of Molecular Biology, Howard Hughes Medical Institute, University of Oregon, Eugene, OR 97403, USA.\",\"publicationStatus\":\"ppublish\",\"language\":\"eng\",\"pubModel\":\"Print\",\"pubTypeList\":{\"pubType\":[\"Research Support, U.S. Gov't, P.H.S.\",\"Research Support, Non-U.S. Gov't\",\"Review\",\"Journal Article\"]},\"grantsList\":{\"grant\":[{\"grantId\":\"GM-50389\",\"agency\":\"NIGMS NIH HHS\",\"acronym\":\"GM\",\"orderIn\":0},{\"grantId\":\"R01 GM050389\",\"agency\":\"NIGMS NIH HHS\",\"acronym\":\"GM\",\"orderIn\":0}]},\"meshHeadingList\":{\"meshHeading\":[{\"majorTopic_YN\":\"N\",\"descriptorName\":\"Peroxidases\",\"meshQualifierList\":{\"meshQualifier\":[{\"abbreviation\":\"ME\",\"qualifierName\":\"metabolism\",\"majorTopic_YN\":\"Y\"},{\"abbreviation\":\"CH\",\"qualifierName\":\"chemistry\",\"majorTopic_YN\":\"N\"}]}},{\"majorTopic_YN\":\"N\",\"descriptorName\":\"Binding Sites\"},{\"majorTopic_YN\":\"N\",\"descriptorName\":\"Protein Conformation\"},{\"majorTopic_YN\":\"N\",\"descriptorName\":\"Dimerization\"},{\"majorTopic_YN\":\"N\",\"descriptorName\":\"Oxidation-Reduction\"},{\"majorTopic_YN\":\"N\",\"descriptorName\":\"Catalysis\"},{\"majorTopic_YN\":\"N\",\"descriptorName\":\"Peroxiredoxins\"}]},\"chemicalList\":{\"chemical\":[{\"name\":\"Peroxidases\",\"registryNumber\":\"EC 1.11.1.-\"},{\"name\":\"Peroxiredoxins\",\"registryNumber\":\"EC 1.11.1.15\"}]},\"subsetList\":{\"subset\":[{\"code\":\"IM\",\"name\":\"Index Medicus\"}]},\"fullTextUrlList\":{\"fullTextUrl\":[{\"availability\":\"Subscription required\",\"availabilityCode\":\"S\",\"documentStyle\":\"doi\",\"site\":\"DOI\",\"url\":\"https://doi.org/10.1016/s0968-0004(02)00003-8\"}]},\"isOpenAccess\":\"N\",\"inEPMC\":\"N\",\"inPMC\":\"N\",\"hasPDF\":\"N\",\"hasBook\":\"N\",\"hasSuppl\":\"N\",\"citedByCount\":1792,\"hasData\":\"Y\",\"hasReferences\":\"Y\",\"hasTextMinedTerms\":\"Y\",\"hasDbCrossReferences\":\"Y\",\"dbCrossReferenceList\":{\"dbName\":[\"INTERPRO\"]},\"hasLabsLinks\":\"Y\",\"hasEvaluations\":\"N\",\"authMan\":\"N\",\"epmcAuthMan\":\"N\",\"nihAuthMan\":\"N\",\"hasTMAccessionNumbers\":\"N\",\"dateOfCompletion\":\"2003-03-04\",\"dateOfCreation\":\"2003-01-09\",\"firstIndexDate\":\"2008-01-29\",\"dateOfRevision\":\"2024-01-09\",\"firstPublicationDate\":\"2003-01-01\"}]}}","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_35","type":"command_execution","command":"/bin/bash -lc \"curl -fsSL 'https://www.ebi.ac.uk/europepmc/webservices/rest/search?query=EXT_ID:21674802%20AND%20SRC:MED&resultType=core&format=json'\"","aggregated_output":"{\"version\":\"6.9\",\"hitCount\":1,\"request\":{\"queryString\":\"EXT_ID:21674802 AND SRC:MED\",\"internalQuery\":\"EXT_ID:21674802 AND SRC:MED\",\"resultType\":\"CORE\",\"cursorMark\":\"*\",\"pageSize\":25,\"sort\":\"\",\"synonym\":false},\"resultList\":{\"result\":[{\"id\":\"21674802\",\"source\":\"MED\",\"pmid\":\"21674802\",\"doi\":\"10.1002/pmic.201000807\",\"title\":\"Proteomics of the oxidative stress response induced by hydrogen peroxide and paraquat reveals a novel AhpC-like protein in Pseudomonas aeruginosa.\",\"authorString\":\"Hare NJ, Scott NE, Shin EH, Connolly AM, Larsen MR, Palmisano G, Cordwell SJ.\",\"authorList\":{\"author\":[{\"fullName\":\"Hare NJ\",\"firstName\":\"Nathan J\",\"lastName\":\"Hare\",\"initials\":\"NJ\",\"authorAffiliationDetailsList\":{\"authorAffiliation\":[{\"affiliation\":\"School of Molecular Bioscience, The University of Sydney, Sydney, Australia.\"}]}},{\"fullName\":\"Scott NE\",\"firstName\":\"Nichollas E\",\"lastName\":\"Scott\",\"initials\":\"NE\",\"authorId\":{\"type\":\"ORCID\",\"value\":\"0000-0003-2556-8316\"}},{\"fullName\":\"Shin EH\",\"firstName\":\"Eun Hye H\",\"lastName\":\"Shin\",\"initials\":\"EH\"},{\"fullName\":\"Connolly AM\",\"firstName\":\"Angela M\",\"lastName\":\"Connolly\",\"initials\":\"AM\"},{\"fullName\":\"Larsen MR\",\"firstName\":\"Martin R\",\"lastName\":\"Larsen\",\"initials\":\"MR\",\"authorId\":{\"type\":\"ORCID\",\"value\":\"0000-0001-6203-0123\"}},{\"fullName\":\"Palmisano G\",\"firstName\":\"Giuseppe\",\"lastName\":\"Palmisano\",\"initials\":\"G\",\"authorId\":{\"type\":\"ORCID\",\"value\":\"0000-0003-1336-6151\"}},{\"fullName\":\"Cordwell SJ\",\"firstName\":\"Stuart J\",\"lastName\":\"Cordwell\",\"initials\":\"SJ\",\"authorId\":{\"type\":\"ORCID\",\"value\":\"0000-0002-0995-0171\"}}]},\"authorIdList\":{\"authorId\":[{\"type\":\"ORCID\",\"value\":\"0000-0001-6203-0123\"},{\"type\":\"ORCID\",\"value\":\"0000-0002-0995-0171\"},{\"type\":\"ORCID\",\"value\":\"0000-0003-1336-6151\"},{\"type\":\"ORCID\",\"value\":\"0000-0003-2556-8316\"}]},\"journalInfo\":{\"issue\":\"15\",\"volume\":\"11\",\"journalIssueId\":1849204,\"dateOfPublication\":\"2011 Aug\",\"monthOfPublication\":8,\"yearOfPublication\":2011,\"printPublicationDate\":\"2011-08-01\",\"journal\":{\"title\":\"Proteomics\",\"medlineAbbreviation\":\"Proteomics\",\"isoabbreviation\":\"Proteomics\",\"nlmid\":\"101092707\",\"essn\":\"1615-9861\",\"issn\":\"1615-9853\"}},\"pubYear\":\"2011\",\"pageInfo\":\"3056-3069\",\"abstractText\":\"Pseudomonas aeruginosa is a ubiquitous pathogen most typically associated with wound infections, but also the main cause of mortality in patients suffering from cystic fibrosis (CF). The ability to adapt to oxidative stress associated with host immune defense may be one mechanism by which P. aeruginosa establishes infection in the cystic fibrosis lung and eventually out-competes other pathogenic bacteria to persist into chronic infection. We utilized a proteomics approach to identify the proteins associated with the oxidative stress response of P. aeruginosa PAO1 to hydrogen peroxide and superoxide-inducing paraquat. 2-DE and MS allowed for the identification of 59 and 58 protein spots that were statistically significantly altered following H(2) O(2) and paraquat treatment, respectively. We observed a unique mass and pI pattern for alkylhydroperoxide reductase C (AhpC) that was replicated by hypothetical protein PA3529 following treatment with 10 mM H(2) O(2) . AhpC belongs to the 2-Cys peroxiredoxin family and is a redox enzyme responsible for removing peroxides in bacterial cells. MS analysis showed that PA3529 was altered by the formation of a dimer via a disulfide bond in a manner analogous to that known for AhpC, and by cysteine overoxidation to Cys-sulfonic acid (SO(3) H) postoxidative stress. PA3529 is therefore a functional AhpC paralog expressed under H(2) O(2) stress. Following paraquat-induced oxidative stress, we also observed the overabundance and likely oxidative modification of a second hypothetical antioxidant protein (PA3450) that shares sequence similarity with 1-Cys peroxiredoxins. Other induced proteins included known oxidative stress proteins (superoxide dismutase and catalase), as well as those involved in iron acquisition (siderophore biosynthesis and receptor proteins FpvA and FptA) and hypothetical proteins, including others predicted to be antioxidants (PA0848). These data suggest that P. aeruginosa contains a plethora of novel antioxidant proteins that contribute to its increased resistance against oxidative stress.\",\"affiliation\":\"School of Molecular Bioscience, The University of Sydney, Sydney, Australia.\",\"publicationStatus\":\"ppublish\",\"language\":\"eng\",\"pubModel\":\"Print-Electronic\",\"pubTypeList\":{\"pubType\":[\"Research Support, Non-U.S. Gov't\",\"Journal Article\"]},\"grantsList\":{\"grant\":[{\"grantId\":\"NHMRC 632788\",\"agency\":\"National Health and Medical Research Council of Australia\",\"orderIn\":0},{\"agency\":\"Australian Postgraduate Award\",\"orderIn\":0},{\"agency\":\"Australian Cystic Fibrosis Research Trust\",\"orderIn\":0},{\"agency\":\"NHMRC Dora Lush Biomedical Research Scholarship\",\"orderIn\":0}]},\"meshHeadingList\":{\"meshHeading\":[{\"majorTopic_YN\":\"N\",\"descriptorName\":\"Pseudomonas aeruginosa\",\"meshQualifierList\":{\"meshQualifier\":[{\"abbreviation\":\"DE\",\"qualifierName\":\"drug effects\",\"majorTopic_YN\":\"Y\"},{\"abbreviation\":\"PH\",\"qualifierName\":\"physiology\",\"majorTopic_YN\":\"Y\"}]}},{\"majorTopic_YN\":\"N\",\"descriptorName\":\"Hydrogen Peroxide\",\"meshQualifierList\":{\"meshQualifier\":[{\"abbreviation\":\"PD\",\"qualifierName\":\"pharmacology\",\"majorTopic_YN\":\"Y\"}]}},{\"majorTopic_YN\":\"N\",\"descriptorName\":\"Paraquat\",\"meshQualifierList\":{\"meshQualifier\":[{\"abbreviation\":\"PD\",\"qualifierName\":\"pharmacology\",\"majorTopic_YN\":\"Y\"}]}},{\"majorTopic_YN\":\"N\",\"descriptorName\":\"Bacterial Proteins\",\"meshQualifierList\":{\"meshQualifier\":[{\"abbreviation\":\"ME\",\"qualifierName\":\"metabolism\",\"majorTopic_YN\":\"N\"}]}},{\"majorTopic_YN\":\"N\",\"descriptorName\":\"Electrophoresis, Gel, Two-Dimensional\"},{\"majorTopic_YN\":\"N\",\"descriptorName\":\"Spectrometry, Mass, Matrix-Assisted Laser Desorption-Ionization\"},{\"majorTopic_YN\":\"N\",\"descriptorName\":\"Proteomics\",\"meshQualifierList\":{\"meshQualifier\":[{\"abbreviation\":\"MT\",\"qualifierName\":\"methods\",\"majorTopic_YN\":\"N\"}]}},{\"majorTopic_YN\":\"N\",\"descriptorName\":\"Oxidative Stress\",\"meshQualifierList\":{\"meshQualifier\":[{\"abbreviation\":\"DE\",\"qualifierName\":\"drug effects\",\"majorTopic_YN\":\"N\"},{\"abbreviation\":\"PH\",\"qualifierName\":\"physiology\",\"majorTopic_YN\":\"Y\"}]}},{\"majorTopic_YN\":\"N\",\"descriptorName\":\"Peroxiredoxins\",\"meshQualifierList\":{\"meshQualifier\":[{\"abbreviation\":\"AN\",\"qualifierName\":\"analysis\",\"majorTopic_YN\":\"N\"},{\"abbreviation\":\"ME\",\"qualifierName\":\"metabolism\",\"majorTopic_YN\":\"Y\"},{\"abbreviation\":\"CH\",\"qualifierName\":\"chemistry\",\"majorTopic_YN\":\"N\"}]}}]},\"chemicalList\":{\"chemical\":[{\"name\":\"Bacterial Proteins\",\"registryNumber\":\"0\"},{\"name\":\"Peroxiredoxins\",\"registryNumber\":\"EC 1.11.1.15\"},{\"name\":\"Hydrogen Peroxide\",\"registryNumber\":\"BBX060AN9V\"},{\"name\":\"Paraquat\",\"registryNumber\":\"PLG39H7695\"}]},\"subsetList\":{\"subset\":[{\"code\":\"IM\",\"name\":\"Index Medicus\"}]},\"fullTextUrlList\":{\"fullTextUrl\":[{\"availability\":\"Subscription required\",\"availabilityCode\":\"S\",\"documentStyle\":\"doi\",\"site\":\"DOI\",\"url\":\"https://doi.org/10.1002/pmic.201000807\"}]},\"isOpenAccess\":\"N\",\"inEPMC\":\"N\",\"inPMC\":\"N\",\"hasPDF\":\"N\",\"hasBook\":\"N\",\"hasSuppl\":\"N\",\"citedByCount\":30,\"hasData\":\"N\",\"hasReferences\":\"Y\",\"hasTextMinedTerms\":\"Y\",\"hasDbCrossReferences\":\"N\",\"hasLabsLinks\":\"N\",\"hasEvaluations\":\"N\",\"authMan\":\"N\",\"epmcAuthMan\":\"N\",\"nihAuthMan\":\"N\",\"hasTMAccessionNumbers\":\"N\",\"dateOfCompletion\":\"2011-11-08\",\"dateOfCreation\":\"2011-06-16\",\"firstIndexDate\":\"2011-06-16\",\"dateOfRevision\":\"2013-11-21\",\"electronicPublicationDate\":\"2011-06-14\",\"firstPublicationDate\":\"2011-06-14\"}]}}","exit_code":0,"status":"completed"}}
